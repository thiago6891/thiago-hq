---
import { contactLinks, emailAddress } from '../lib/site-content';

const contactEntries = Object.entries(contactLinks);
---

<div class="grid gap-8 rounded-lg border border-line bg-[#eeece5] p-7 sm:p-9 lg:grid-cols-[1fr_auto] lg:items-end">
	<div>
		<p class="text-sm font-semibold tracking-[0.18em] text-accent uppercase">Contact</p>
		<h2 class="mt-3 max-w-2xl text-3xl font-semibold">Looking for a senior engineer who can own the work from plan to production?</h2>
		<p class="mt-3 leading-7 text-muted">
			Just say <a class="font-semibold text-ink transition hover:text-accent" href={`mailto:${emailAddress}`}>{emailAddress}</a>
		</p>
		<p class="mt-4 max-w-2xl leading-7 text-muted">I'm open to remote senior and staff-level contract roles, as well as conversations about relevant projects.</p>
		<div class="mt-6 flex flex-wrap gap-2 text-sm text-muted" aria-label="Additional links">
			{
				contactEntries
					.filter(([label]) => label !== 'Email')
					.map(([label, link]) => {
						return (
							<a
								class="inline-flex size-8 items-center justify-center rounded-full transition hover:bg-white/70 hover:text-ink focus:outline-2 focus:outline-offset-2 focus:outline-accent sm:size-9"
								href={link.href}
								target={link.opensInNewTab ? '_blank' : undefined}
								rel={link.opensInNewTab ? 'noreferrer' : undefined}
								aria-label={label}
								title={label}
							>
								<link.icon />
							</a>
						);
					})
			}
		</div>
	</div>
</div>
