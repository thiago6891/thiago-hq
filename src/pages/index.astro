---
import { getCollection } from 'astro:content';
import ContactBlock from '../components/ContactBlock.astro';
import SiteHeader from '../components/SiteHeader.astro';
import { expertise, selectedResults } from '../lib/site-content';
import '../styles/global.css';

const caseStudies = await getCollection('case-studies');
---

<html lang="en" class="scroll-smooth">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<meta
			name="description"
			content="Senior software engineer specializing in backend systems, cloud infrastructure, and pragmatic full-stack product engineering."
		/>
		<title>Thiago Cordeiro | Senior Software Engineer</title>
	</head>
	<body class="bg-paper text-ink antialiased">
		<main class="mx-auto flex min-h-screen w-full max-w-6xl flex-col px-5 py-6 sm:px-8 lg:px-12">
			<SiteHeader />

			<section class="grid items-center gap-10 py-14 sm:py-18 lg:grid-cols-[minmax(0,1fr)_280px] lg:py-24">
				<div class="max-w-3xl">
					<p class="text-sm font-semibold tracking-[0.16em] text-accent uppercase">
						Senior Software Engineer · Brazil (UTC-3)
					</p>
					<h1 class="mt-5 max-w-4xl text-4xl leading-[1.05] font-semibold text-balance sm:text-6xl lg:text-7xl">
						I build backend systems and products that small teams can rely on.
					</h1>
					<p class="mt-7 max-w-2xl text-lg leading-8 text-muted sm:text-xl">
						My work spans backend architecture, cloud infrastructure, and pragmatic full-stack product engineering—from technical planning through production.
					</p>
					<p class="mt-4 max-w-2xl leading-7 text-muted">
						I'm available for remote senior and staff-level contract roles, as well as relevant projects.
					</p>
					<div class="mt-9 flex flex-wrap gap-3" aria-label="Primary actions">
						<a class="button-primary" href="#case-studies">View case studies</a>
						<a class="button-secondary" href="#contact">Get in touch</a>
					</div>
				</div>

				<aside class="w-full max-w-sm justify-self-start lg:justify-self-end" aria-label="Portrait of Thiago">
					<div class="size-56 overflow-hidden rounded-full border border-line bg-[#ebe7dd] p-3 shadow-sm sm:size-64">
						<img class="h-full w-full rounded-full object-cover" src="/portrait.jpeg" alt="Thiago Cordeiro" loading="eager" decoding="async" />
					</div>
				</aside>
			</section>

			<section id="about" class="border-t border-line py-14 sm:py-18">
				<div class="grid gap-8 lg:grid-cols-[240px_minmax(0,1fr)] lg:gap-16">
					<div>
						<p class="section-label">About</p>
						<h2 class="mt-3 text-3xl font-semibold">Pragmatic engineering for small, ambitious teams.</h2>
					</div>
					<div class="max-w-3xl space-y-5 text-lg leading-8 text-muted">
						<p>
							I have 11+ years of software experience, including the last five working remotely as a contractor for startups in the US and Europe.
						</p>
						<p>
							My strongest work sits at the intersection of backend architecture, technical planning, and product execution. I'm drawn to problems where the hard part is not just writing code, but sequencing the work, clarifying tradeoffs, and reducing operational risk.
						</p>
						<p>
							The goal is always the same: turn messy product requirements into systems a small team can realistically build, operate, and maintain.
						</p>
					</div>
				</div>
			</section>

			<section id="results" class="border-t border-line py-14 sm:py-18">
				<div class="max-w-2xl">
					<p class="section-label">Selected results</p>
					<h2 class="mt-3 text-3xl font-semibold">A few outcomes from the work.</h2>
				</div>
				<div class="mt-10 grid border-t border-line sm:grid-cols-2 lg:grid-cols-3">
					{selectedResults.map((result) => (
						<article class="result-item border-b border-line py-7 sm:px-6 sm:first:pl-0 lg:py-8">
							<p class="text-3xl font-semibold tracking-tight text-accent">{result.metric}</p>
							<p class="mt-3 max-w-xs leading-7 text-muted">{result.description}</p>
						</article>
					))}
				</div>
			</section>

			<section id="expertise" class="border-t border-line py-14 sm:py-18">
				<div class="grid gap-8 lg:grid-cols-[240px_minmax(0,1fr)] lg:gap-16">
					<div>
						<p class="section-label">Core expertise</p>
						<h2 class="mt-3 text-3xl font-semibold">The tools follow the problem.</h2>
					</div>
					<dl class="divide-y divide-line border-y border-line">
						{expertise.map((item) => (
							<div class="grid gap-2 py-5 sm:grid-cols-[150px_1fr] sm:gap-6">
								<dt class="font-semibold">{item.label}</dt>
								<dd class="leading-7 text-muted">{item.items}</dd>
							</div>
						))}
					</dl>
				</div>
			</section>

			<section id="case-studies" class="border-t border-line py-14 sm:py-18">
				<div class="max-w-2xl">
					<p class="section-label">Case studies</p>
					<h2 class="mt-3 text-3xl font-semibold">Selected work, in detail.</h2>
					<p class="mt-4 leading-7 text-muted">The decisions, tradeoffs, and results behind projects I've led.</p>
				</div>
				<div class="mt-10 grid gap-8 sm:grid-cols-2">
					{caseStudies.map((entry) => (
						<a class="case-study-card group" href={`/case-studies/${entry.id}`}>
							{entry.data.coverImage && (
								<div class="aspect-video overflow-hidden rounded-lg border border-line bg-white">
									<img class="h-full w-full object-cover transition duration-300 group-hover:scale-[1.02]" src={entry.data.coverImage} alt={entry.data.coverImageAlt ?? ''} loading="lazy" decoding="async" />
								</div>
							)}
							<h3 class="mt-5 text-xl font-semibold leading-snug text-balance transition group-hover:text-accent">{entry.data.title}</h3>
							<p class="mt-3 leading-7 text-muted">{entry.data.summary}</p>
							<span class="mt-4 inline-block text-sm font-semibold text-accent">Read case study →</span>
						</a>
					))}
				</div>
			</section>

			<section id="contact" class="border-t border-line py-14 sm:py-16">
				<ContactBlock />
			</section>
		</main>
	</body>
</html>
