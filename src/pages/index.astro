---
import {
	contactLinks,
	emailAddress,
	problemRecognition,
	whatIBring,
} from '../lib/site-content';
import '../styles/global.css';

const contactEntries = Object.entries(contactLinks);
---

<html lang="en" class="scroll-smooth">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<meta
			name="description"
			content="I help remote teams turn ambiguous technical work into clear plans, maintainable systems, and shipped software."
		/>
		<title>Thiago Cordeiro | Software Engineer</title>
	</head>
	<body class="bg-paper text-ink antialiased">
		<main class="mx-auto flex min-h-screen w-full max-w-6xl flex-col px-5 py-6 sm:px-8 lg:px-12">
			<header class="flex items-center justify-between gap-3 border-b border-line pb-5">
				<a class="shrink-0 text-base font-semibold tracking-[0.08em] uppercase" href="/">Thiago Cordeiro</a>
				<nav aria-label="Contact links" class="flex shrink-0 flex-nowrap justify-end gap-x-1 text-sm text-muted">
					{
						contactEntries.map(([label, link]) => {
							return (
								<a
									class="inline-flex size-7 items-center justify-center rounded-full transition hover:bg-white/70 hover:text-ink focus:outline-2 focus:outline-offset-2 focus:outline-accent sm:size-9"
									href={link.href}
									target={link.opensInNewTab ? '_blank' : undefined}
									rel={link.opensInNewTab ? 'noreferrer' : undefined}
									aria-label={label}
									title={label}
								>
									<link.icon />
								</a>
							);
						})
					}
				</nav>
			</header>

			<section class="grid items-center gap-10 py-14 sm:py-18 lg:grid-cols-[minmax(0,1fr)_280px] lg:py-20">
				<div class="max-w-3xl">
					<h1 class="max-w-4xl text-4xl leading-[1.05] font-semibold text-balance sm:text-6xl lg:text-7xl">
						Software engineer focused on clarity, ownership, and reliable delivery.
					</h1>
					<p class="mt-7 max-w-2xl text-lg leading-8 text-muted sm:text-xl">
						I help remote teams turn ambiguous technical work into clear plans, maintainable systems, and shipped software.
					</p>
					<p class="mt-5 max-w-2xl leading-7 text-muted">
						When requirements are unclear, mental models differ, ownership is missing, documentation is stale, and small changes take too long, I help teams make the work understandable enough to move forward.
					</p>
					<div class="mt-9 flex flex-wrap gap-3" aria-label="Primary actions">
						<a
							class="inline-flex items-center justify-center rounded-full bg-ink px-6 py-3 text-sm font-semibold text-white transition hover:bg-accent focus:outline-2 focus:outline-offset-2 focus:outline-accent"
							href="#contact"
						>
							Contact me
						</a>
					</div>
				</div>

				<aside class="w-full max-w-sm justify-self-start lg:justify-self-end" aria-label="Portrait of Thiago">
					<div class="size-64 overflow-hidden rounded-full border border-line bg-[#ebe7dd] p-3 shadow-sm sm:size-72">
						<img
							class="h-full w-full rounded-full object-cover"
							src="/portrait.jpeg"
							alt="Portrait of Thiago"
							loading="eager"
							decoding="async"
						/>
					</div>
				</aside>
			</section>

			<section id="problem" class="border-t border-line py-14 sm:py-16">
				<div class="grid gap-9 lg:grid-cols-[260px_1fr]">
					<div>
						<p class="text-sm font-semibold tracking-[0.18em] text-accent uppercase">Problem recognition</p>
						<h2 class="mt-3 max-w-sm text-3xl font-semibold">The hard part is often making the work clear.</h2>
					</div>
					<div class="grid gap-4 sm:grid-cols-2">
						{
							problemRecognition.map((item) => (
								<article class="border-t border-line py-5">
									<h3 class="text-lg font-semibold">{item.title}</h3>
									<p class="mt-3 leading-7 text-muted">{item.text}</p>
								</article>
							))
						}
					</div>
				</div>
			</section>

			<section id="what-i-bring" class="border-t border-line py-14 sm:py-16">
				<div class="grid gap-9 lg:grid-cols-[240px_1fr]">
					<div>
						<p class="text-sm font-semibold tracking-[0.18em] text-accent uppercase">What I bring</p>
						<h2 class="mt-3 text-3xl font-semibold">Practical judgment from plan to production.</h2>
					</div>
					<div class="grid gap-4 sm:grid-cols-2">
						{
							whatIBring.map((item) => (
								<article class="rounded-lg border border-line bg-white/50 p-6">
									<h3 class="text-lg font-semibold">{item.title}</h3>
									<p class="mt-3 leading-7 text-muted">{item.text}</p>
								</article>
							))
						}
					</div>
				</div>
			</section>

			<section id="contact" class="border-t border-line py-14 sm:py-16">
				<div class="grid gap-8 rounded-lg border border-line bg-[#eeece5] p-7 sm:p-9 lg:grid-cols-[1fr_auto] lg:items-end">
					<div>
						<p class="text-sm font-semibold tracking-[0.18em] text-accent uppercase">Contact</p>
						<h2 class="mt-3 max-w-2xl text-3xl font-semibold">Need help turning unclear technical work into shipped software?</h2>
						<p class="mt-4 max-w-2xl leading-7 text-muted">
							Just say <a class="font-semibold text-ink transition hover:text-accent" href={`mailto:${emailAddress}`}>{emailAddress}</a>
						</p>
						<div class="mt-6 flex flex-wrap gap-2 text-sm text-muted" aria-label="Additional links">
							{
								contactEntries
									.filter(([label]) => label !== 'Email')
									.map(([label, link]) => {
										return (
											<a
												class="inline-flex size-8 items-center justify-center rounded-full transition hover:bg-white/70 hover:text-ink focus:outline-2 focus:outline-offset-2 focus:outline-accent sm:size-9"
												href={link.href}
												target={link.opensInNewTab ? '_blank' : undefined}
												rel={link.opensInNewTab ? 'noreferrer' : undefined}
												aria-label={label}
												title={label}
											>
												<link.icon />
											</a>
										);
									})
							}
						</div>
					</div>
				</div>
			</section>
		</main>
	</body>
</html>
